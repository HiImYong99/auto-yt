{
  "name": "auto-yt",
  "version": "1.0.0",
  "description": "Auto YouTube video generator with Remotion + ElevenLabs",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts MainVideo out/video.mp4",
    "render": "remotion render src/index.ts MainVideo out/video.mp4",
    "thumbnail": "remotion still src/index.ts Thumbnail out/thumbnail.png --frame=0",
    "start:cli": "ts-node --project tsconfig.node.json src/cli/index.ts",
    "start:web": "ts-node --project tsconfig.node.json src/web/server.ts"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.290",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.290"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
